{
  "name": "realitycentral",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc && node scripts/ui-contract-check.mjs",
    "pages:dev": "wrangler pages dev dist --d1 DB=realitycentral-db",
    "db:migrate:local": "wrangler d1 migrations apply realitycentral-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply realitycentral-db --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250917.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "wrangler": "^4.38.0"
  }
}
